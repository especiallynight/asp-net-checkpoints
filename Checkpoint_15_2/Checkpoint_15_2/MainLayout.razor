@using Checkpoint_15_2.Pages
@using Checkpoint_15_2.Services
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@currentTitle</PageTitle>

<div class="main">
    <div class="top-bar">
        <LanguageSwitcher />
        <Notification />  
    </div>
    @Body
</div>

@code {
    private string currentTitle = "Главная страница";

    protected override void OnInitialized()
    {
        UpdateTitle(NavigationManager.Uri);  
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object sender, LocationChangedEventArgs e)
    {
        UpdateTitle(e.Location);
    }

    private void UpdateTitle(string location)
    {
        if (location.Contains("details"))
        {
            currentTitle = Loc.GetText("Details");
        }
        else if (location.Contains("products"))
        {
            currentTitle = Loc.GetText("Products");
        }
        else if (location.Contains("dynamic-content"))
        {
            currentTitle = Loc.GetText("DynamicContent");
        }
        else
        {
            currentTitle = Loc.GetText("Welcome");
        }

        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}