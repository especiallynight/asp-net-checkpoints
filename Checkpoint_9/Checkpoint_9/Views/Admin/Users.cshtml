@model IEnumerable<Checkpoint_9.Models.ApplicationUser>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Users</title>

</head>
<body>
    <h2>User Management</h2>
    <a href="/Admin/CreateUser" class="btn btn-primary">Create New User</a>

    <table>
        <thead>
            <tr>
                <th>Email</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.FirstName</td>
                    <td>@user.LastName</td>
                    <td>
                        <a href="/Admin/EditUser?id=@user.Id" class="btn btn-primary">Edit</a>
                        <a href="/Admin/DeleteUser?id=@user.Id" class="btn btn-warning" onclick="return confirm('Are you sure?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>