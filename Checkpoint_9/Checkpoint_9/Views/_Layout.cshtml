<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Checkpoint_9</a>
            <div class="navbar-nav ms-auto">
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="nav-item nav-link text-light">@User.Identity.Name</span>
                    <a class="nav-item nav-link" href="/Account/Logout">Logout</a>
                }
                else
                {
                    <a class="nav-item nav-link" href="/Account/Login">Login</a>
                }
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>
</body>
</html>