          "email",
          "firstName",
          "lastName",
          "password"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 3,
            "pattern": "^[a-zA-Zа-яА-Я]+$",
            "type": "string"
          },
          "lastName": {
            "minLength": 3,
            "pattern": "^[a-zA-Zа-яА-Я]+$",
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 8,
            "pattern": "^(?=.*[A-Za-z])(?=.*\\d).+$",
            "type": "string",
            "format": "password"
          },
          "confirmPassword": {
            "minLength": 1,
            "type": "string",
            "format": "password"
          }
        },
        "additionalProperties": false
      },
