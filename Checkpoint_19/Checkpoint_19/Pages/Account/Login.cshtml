@page
@model Checkpoint_19.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<h2>Вход в систему</h2>

<form method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Username">Имя пользователя</label>
        <input asp-for="Username" class="form-control" style="width: 280px;" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Password">Пароль</label>
        <input asp-for="Password" type="password" class="form-control" style="width: 280px;" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Войти</button>
</form>

<a asp-page="/Account/Register" class="mt-2 d-block">Регистрация</a>